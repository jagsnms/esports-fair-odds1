  "definitions": {
    "PHAT": {
      "name": "p_hat",
      "meaning": "P(Team A wins the series | current game state)",
      "range": [
        0.0,
        1.0
      ]
    },
    "q": {
      "name": "q_round_win",
      "meaning": "P(Team A wins the current round | current round state)",
      "range": [
        0.0,
        1.0
      ]
    },
    "rails": {
      "rail_high": "Series probability if Team A wins the round (conditional endpoint)",
      "rail_low": "Series probability if Team B wins the round (conditional endpoint)"
    }
  },
  "core_architecture": {
    "target_variable": "PHAT",
    "core_equation": {
      "type": "coupling",
      "expression": "target_p_hat = rail_low + q * (rail_high - rail_low)",
      "must_hold_structurally": true,
      "notes": [
        "PHAT is derived through q and rails; direct additive feature updates to PHAT are forbidden.",
        "PHAT movement toward target_p_hat is governed by movement dynamics (confidence/inertia)."
      ]
    },
    "calculation_flow": [
      "ingest_normalized_round_state",
      "compute_combat_capability",
      "apply_objective_state_modifiers",
      "apply_timer_pressure_scaler",
      "compute_q_round_win",
      "compute_rails_tick_dynamic",
      "compute_target_p_hat_from_q_and_rails",
      "apply_movement_confidence_inertia_update",
      "emit_outputs_and_diagnostics"
    ]
  },
  "signal_model": {
    "groups": {
      "combat_strength": {
        "inputs": [
          "players_alive",
          "hp_state",
          "loadout_value"
        ],
        "notes": [
          "Represents effective fighting capability.",
          "Relative combat advantage drives q before objective/timer adjustments."
        ]
      },
      "objective_state": {
        "inputs": [
          "bomb_planted",
          "bomb_timer_remaining"
        ],
        "notes": [
          "Objective state modifies interpretation of combat state.",
          "Bomb plant can be strategic for money; model should not treat plant as universally dominant."
        ]
      },
      "timer_pressure": {
        "inputs": [
          "round_time_remaining",
          "bomb_timer_remaining",
          "bomb_planted"
        ],
        "notes": [
          "Timer acts as a scaler that amplifies advantage as time approaches zero.",
          "Pre-plant pressure favors CT; post-plant pressure favors T."
        ],
        "curve_intent": {
          "shape": "accelerating_non_linear",
          "interpretation": "Differences near 0 seconds matter far more than differences early in the timer."
        }
      }
    },
    "hierarchy_rule": {
      "fixed_groups": [
        "combat_strength",
        "objective_state",
        "timer_pressure"
      ],
      "calibration_may_tune_within_groups": true,
      "calibration_may_reweight_between_groups": false,
      "future_extension_allowed": true,
      "future_extension_note": "Group hierarchy is fixed for now; may be relaxed later if justified by testing."
    }
  },
  "rails_contract": {
    "dynamic": true,
    "recomputed_each_tick": true,
    "meaning": "Conditional series endpoints if the round resolves immediately, with endpoints varying based on carryover-relevant context (envelope concept).",
    "dependency_policy": {
      "allowed_inputs": [
        "teamA_cash_total",
        "teamB_cash_total",
        "teamA_loadout_value",
        "teamB_loadout_value",
        "loss_bonus_state",
        "saved_weapons_value_teamA",
        "saved_weapons_value_teamB",
        "persistent_equipment_value"
      ],
      "forbidden_inputs": [
        "hp_remaining",
        "positioning_or_map_control",
        "utility_remaining_transient",
        "round_time_remaining",
        "bomb_planted_state_as_transient",
        "time_remaining_when_round_ended"
      ],
      "notes": [
        "Only 'quality of win' signals that persist across the round boundary may shape rail endpoints.",
        "Opponent economy and carryover outlook are allowed and important."
      ]
    }
  },
  "movement_model": {
    "principle": "PHAT moves toward target_p_hat, not instant jumps.",
    "update_form": {
      "expression": "p_hat_next = p_hat + confidence * (target_p_hat - p_hat)",
      "confidence_range": [
        0.0,
        1.0
      ],
      "confidence_behavior": "increases_as_round_approaches_resolution",
      "notes": [
        "Early round: low confidence (slow movement).",
        "Late round: high confidence (fast convergence).",
        "Avoid cosmetic smoothing that hides diagnostic issues during testing."
      ]
    },
    "optional_safety": {
      "production_display_clamp_allowed": true,
      "testing_clamp_forbidden": true,
      "must_emit_diagnostics_when_triggered": true,
      "explicitly_configurable": true
    }
  },
  "invariants": {
    "structural_hard": [
      {
        "id": "INV_STRUCT_Q_RANGE",
        "expr": "0 <= q <= 1",
        "severity": "fail"
      },
